link-workspace-packages=true
prefer-workspace-packages=true
shared-workspace-lockfile=true
auto-install-peers=true
strict-peer-dependencies=false
# Plug-and-play modules (modules/*) consume runtime libs (react, jspdf, express, pg, multer)
# without re-declaring every dep. Hoisting flattens node_modules so any workspace package
# can resolve them, matching the previous npm behaviour.
node-linker=hoisted
