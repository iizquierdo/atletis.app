# Frontend (Vite) env
VITE_PORT=13509
VITE_BASE_URL=/

# Backend URL — Vite dev server proxies /api and /storage to this target.
VITE_API_PROXY_TARGET=http://localhost:14000

# Prod (separate Railway services): set at BUILD time so the SPA calls the API host.
# Must be a full origin — include https:// (bare hostnames also work after normalize).
# VITE_API_BASE_URL=https://atletis-api.up.railway.app
# VITE_ALLOWED_HOSTS=atletis.up.railway.app

# Public PWA origins used by /install/{organizationId}
VITE_PWA_PARENT_URL=http://localhost:13510
VITE_PWA_PROFESSOR_URL=http://localhost:13511

# Optional features
# GEMINI_API_KEY=
