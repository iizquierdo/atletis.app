# API standalone server settings
API_PORT=14000
API_HOST=0.0.0.0

# CORS — comma-separated browser origins (required when web and API are on different domains).
# Dev: http://localhost:13509  |  Railway example: https://atletis.up.railway.app
WEB_ORIGIN=http://localhost:13509

# Postgres (required). On Railway, reference the Postgres plugin variable.
# DATABASE_URL=postgresql://...

# Inherits DATABASE_URL, ADMIN_EMAIL, ADMIN_PASSWORD, ADMIN_JWT_SECRET from repo-root .env

# Optional overrides
# MODULES_ROOT=../../modules
# STORAGE_ROOT=./storage
