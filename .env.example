# Docker Compose: project name (prefix for containers, networks, volumes).
# Override per clone/machine to avoid collisions (default matches folder sinapsis.app → sinapsisapp).
COMPOSE_PROJECT_NAME=golplay
COMPOSE_PROJECT_PORT=15432
# Vite public base URL (use / or e.g. /app/ when hosted under a subpath)
VITE_BASE_URL=/

# Optional: Gemini (existing app usage via Vite define)
# GEMINI_API_KEY=

# SaaS platform admin credentials for /admin
ADMIN_EMAIL=admin@saas.local
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=replace-with-a-long-random-secret
